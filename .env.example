# ── Dashboard login ─────────────────────────────────────────────────────── #
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_before_deploy

# ── JWT signing secret (use a long random string) ──────────────────────── #
JWT_SECRET=replace_with_a_long_random_secret_string_here
JWT_EXPIRY_HOURS=24

# ── Encryption key for API key storage ─────────────────────────────────── #
# Must be stable across restarts; changing it invalidates all stored keys.
ENCRYPTION_KEY=replace_with_32_plus_char_secret_for_aes_key

# ── Persistence paths ──────────────────────────────────────────────────── #
# These must be ABSOLUTE paths on the host server.
# They are used as bind mount sources in docker-compose.yml so that logs
# and data are accessible directly from the host without entering the container.
# The container always sees them internally as /app/data and /app/logs.
#
# Example (match your actual server layout):
DATA_DIR=/home/gre8/forexnews.gre8i.com/Forex-news-Scraper/data
LOGS_DIR=/home/gre8/forexnews.gre8i.com/Forex-news-Scraper/logs

# local host
#DATA_DIR=/home/josewathome/Projects/forex-news-scraping/data
#LOGS_DIR=/home/josewathome/Projects/forex-news-scraping/logs

# ── Log retention ──────────────────────────────────────────────────────── #
LOG_RETENTION_DAYS=3
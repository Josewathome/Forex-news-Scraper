# ── Dashboard login ─────────────────────────────────────────────────────── #
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_before_deploy

# ── JWT signing secret (use a long random string) ──────────────────────── #
JWT_SECRET=replace_with_a_long_random_secret_string_here
JWT_EXPIRY_HOURS=24

# ── Encryption key for API key storage ─────────────────────────────────── #
# Must be stable across restarts; changing it invalidates all stored keys.
ENCRYPTION_KEY=replace_with_32_plus_char_secret_for_aes_key

# ── Persistence paths (should match Docker volume mounts) ──────────────── #
DATA_DIR=data
LOGS_DIR=logs

# ── Log retention ──────────────────────────────────────────────────────── #
LOG_RETENTION_DAYS=3
